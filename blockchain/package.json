{
  "name": "trustlend-blockchain",
  "version": "1.0.0",
  "description": "TrustLend smart contracts — Hardhat workspace",
  "scripts": {
    "compile":        "hardhat compile",
    "test":           "hardhat test",
    "node":           "hardhat node",
    "deploy:local":   "hardhat run scripts/deploy.js --network localhost",
    "deploy:mumbai":  "hardhat run scripts/deploy.js --network mumbai",
    "deploy:amoy":    "hardhat run scripts/deploy.js --network amoy",
    "verify:mumbai":  "hardhat verify --network mumbai"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.0.0"
  }
}
