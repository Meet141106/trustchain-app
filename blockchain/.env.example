# Blockchain environment variables
# Copy this file to .env and fill in your values

# Your wallet private key (NO 0x prefix needed by some tools — check your setup)
# NEVER commit the real .env to git
PRIVATE_KEY=your_private_key_here

# Polygon Mumbai RPC (get one free at https://maticvigil.com or https://alchemy.com)
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# Polygon Amoy RPC (new testnet, more stable)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# PolygonScan API key for contract verification (optional)
# Get at: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=your_polygonscan_key_here
