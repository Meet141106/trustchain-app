# ============================================
# TrustLend Environment Configuration
# Copy this file to .env and fill in values
# NEVER commit .env to GitHub
# ============================================

# ---- BLOCKCHAIN ----
# Local Hardhat node
VITE_RPC_URL=http://127.0.0.1:8545
VITE_NETWORK_MODE=local
VITE_EXPLORER_URL=http://127.0.0.1:8545
# For Polygon Amoy production:
# VITE_RPC_URL=https://rpc-amoy.polygon.technology
# VITE_NETWORK_MODE=amoy
# VITE_EXPLORER_URL=https://amoy.polygonscan.com

# ---- ML API ----
# Local development
VITE_ML_API_URL=http://localhost:8000
# After Render deploy:
# VITE_ML_API_URL=https://trustlend-ai.onrender.com

# ---- SUPABASE ----
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
